# ─── ClienteLoop Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── Supabase (Auth & Database) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUz...your_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres

# ─── AI (Anthropic Claude) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=3001
CORS_ORIGIN=http://localhost:4000

# ─── Frontend (Vite injects VITE_ vars into client bundle) ──────────────────
VITE_APP_NAME=ClienteLoop
# In production, set this to your Railway backend URL:
# VITE_API_URL=https://your-backend.up.railway.app

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_AI=true
ENABLE_CHANNELS=false
ENABLE_AUTO_REPLY=false

# ─── Infobip (Multi-Channel Messaging) ──────────────────────────────────────
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_BASE_URL=https://xxxxx.api.infobip.com
INFOBIP_WHATSAPP_SENDER=+1234567890
INFOBIP_SMS_SENDER=ClienteLoop
INFOBIP_EMAIL_FROM=noreply@yourdomain.com
# Optional: HMAC secret for webhook signature verification
# INFOBIP_WEBHOOK_SECRET=your_webhook_hmac_secret
