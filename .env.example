# ClienteLoop Environment Configuration
# Copy this file to .env and fill in your values.

# Supabase (Auth & Database)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUz...your_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres

# AI
# Current implementation uses Gemini.
GEMINI_API_KEY=your_gemini_api_key

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=your_meta_permanent_access_token
META_PHONE_ID=your_whatsapp_phone_number_id
META_VERIFY_TOKEN=any_random_string_for_webhook_verification
META_APP_SECRET=your_meta_app_secret
FACEBOOK_APP_ID=your_meta_app_id

# Meta Embedded Signup (frontend)
VITE_FACEBOOK_APP_ID=your_meta_app_id
VITE_FACEBOOK_CONFIG_ID=your_embedded_signup_config_id

# Server
SERVER_PORT=3001
CORS_ORIGIN=http://localhost:4000
NODE_ENV=development

# Frontend (Vite injects VITE_ vars into client bundle)
VITE_APP_NAME=ClienteLoop
# In production, set this to your Railway backend URL:
# VITE_API_URL=https://your-backend.up.railway.app

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_SEAT=price_...

# Feature Flags
ENABLE_AI=true
ENABLE_CHANNELS=false      # Set to true to send real WhatsApp messages via Meta API
ENABLE_AUTO_REPLY=false    # Set to true to auto-reply incoming messages with AI
